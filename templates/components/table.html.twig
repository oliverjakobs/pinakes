<div hx-table-content class="table-container">

<table class="table">
  <thead>
    <tr>
    {% for field in table.dataFields %}
    {# TODO order by datafield #}
    {# TODo change cursor on hover #}
      {% set can_order_by = (allow_ordering ?? true) and field.canOrderBy %}
      {% if can_order_by %}
        {% set direction = (field.property == table.filter.order_by) ? table.filter.order_dir : '' %}
      {% else %}
        {% set direction = '' %}
      {% endif %}
      <th
        {% if can_order_by %}
          hx-get="{{ filter_url(app.request, table.filter, {
            'order_by': field.property,
            'order_dir': (direction == 'asc') ? 'desc' : 'asc',
            'page': 1
          }) }}"
          hx-trigger="click"
          hx-swap="outerHTML"
          hx-target="[hx-table-content]"
        {% endif %}
      >
        {% if field.caption is defined %}
          <div class="caption {{ direction }}">{{ field.caption }}</div>
        {% endif %}
      </th>
    {% endfor %}
    </tr>
  </thead>
  <tbody>
  {% for entity in table.currentPage %}
    <tr>
    {% for field in table.dataFields %}
      {{ render_value(entity, field) | raw }}
    {% endfor %}
    </tr>
  {% else %}
    <tr class="empty">
      <td colspan="{{ table.dataFields|length }}">Nothing found!</td>
    </tr>
  {% endfor %}
  </tbody>
</table>

{% if allow_pagination ?? true %}
  {% include 'elements/pagination.html.twig' with {
    'table': table
  } only %}
{% endif %}

</div>
