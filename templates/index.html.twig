{% extends "_base.html.twig" %}

{% block stylesheets %}
    <link rel="stylesheet" href={{ asset('styles/bookfund.css') }}>
{% endblock %}

{% block content %}

<div class="container">

  <h1>Bookfund</h1>

  <div class="balance-card">
    <h2>Balance</h2>
    <div class="balance">
      {{ balance | fmt_currency }}
    </div>
  </div>

  <h1>Newest Books</h1>
  {% include 'components/table.html.twig' with {
    'allow_ordering': false,
    'allow_pagination': false,
    'table': newest
  } %}

</div>

{% endblock %}
