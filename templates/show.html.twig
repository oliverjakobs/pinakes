{% extends "_base.html.twig" %}

{% block title %}
  Pinakes - {{ entity }}
{% endblock %}

{% block content %}
<div class="show">
  <h1>{{ entity }}</h1>

  <table>
    <tbody>
    {% for field in fields %}
      <tr>
        <td class="fit-content caption">{{ field.caption }}:</td>
        {{ render_value(field, entity) | raw }}
      </tr>
    {% endfor %}
    </tbody>
  </table>

</div>

{% endblock %}
