{% extends "_base.html.twig" %}

{% block title %}
  Pinakes - {{ title }}
{% endblock %}

{% block content %}

<div class="container">
  <h1>{{ title }}</h1>

  <div class="table-control">
    <input
      class="table-search"
      type="search"
      placeholder="Search..."
      name="search"
      value="{{ table.search }}"
      hx-trigger="keyup[key=='Enter']"
      hx-get="{{ filter_url(app.request, table) }}"
      hx-target="[hx-table-content]">
    {% if filters is not empty %}
    <label
      id="table-filter-label"
      for="table-filter-check" 
      onclick="this.classList.toggle('checked')">
      Filter
    </label>
    {% endif %}
  </div>
  {% if filters is not empty %}
  <div class="table-filter">
    <input type="checkbox" id="table-filter-check">
    <div class="filter-dropdown">
      <form 
        hx-get="{{ filter_url(app.request, table) }}"
        hx-target="[hx-table-content]">
        {% for form in filters %}
          <div>
            <label for="{{ form.name }}">{{ form.caption }}</label>
            {{ render_filter(table, form) | raw }}
          </div>
        {% endfor %}
        <button type="submit">Apply</button>
      </form>
    </div>
  </div>
  {% endif %}
  {% include table.componentPath %}
</div>
{% endblock %}
